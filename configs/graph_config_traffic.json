{
    "seed": 2305,
    "base_lr": 5e-5,
    "base_batch": 1024,
    "num_mul": 15,
    "hidden_channels": 256,
    "num_layers": 4,
    "num_heads": 4,
    "dropout": 0.3,
    "min_lr": 1e-6,
    "weight_decay": 0.01,
    "epochs": 2000,
    "patience": 10,
    "warmup_factor": 0.1,
    "lr_scale_method": "linear",
    "use_label_smoothing": true,
    "label_smoothing": 0.1,
    "drop_edge_rate": 0.2,
    "inductive": false,
    "max_grad_norm": 1.0,
    "activation": "gelu",
    "num_workers": 8,
    "num_neighbors": [
        15, 10, 5
    ],
    "train_size": 0.6,
    "test_size": 0.2,
    "valid_size": 0.2,
    "prefetch_factor": 4,
    "data_path": "../code/data/NF-CSE-CIC-IDS2018-v3/traffic_graph",
    "mode": "multi",
    "use_class_weight": true,
    "use_focal_loss": true,
    "focal_gamma": 3.0,
    "use_edge_features": true,
    "use_tpa": true,
    "useTrans": false,
    "useGCN": false,
    "useSAGE": false,
    "use_tpa_fusion": false,
    "use_flash_tpa": false,
    "tensor_edge_mode": "hybrid"
}